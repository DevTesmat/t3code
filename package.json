{
  "name": "@t3tools/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "scripts"
    ],
    "catalog": {
      "effect": "4.0.0-beta.45",
      "@effect/atom-react": "4.0.0-beta.45",
      "@effect/openapi-generator": "4.0.0-beta.45",
      "@effect/platform-bun": "4.0.0-beta.45",
      "@effect/platform-node": "4.0.0-beta.45",
      "@effect/platform-node-shared": "4.0.0-beta.45",
      "@effect/sql-sqlite-bun": "4.0.0-beta.45",
      "@effect/vitest": "4.0.0-beta.45",
      "@effect/language-service": "0.84.2",
      "@types/bun": "^1.3.11",
      "@types/node": "^24.12.2",
      "tsdown": "^0.20.3",
      "typescript": "^5.7.3",
      "vitest": "^4.1.5"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev-runner.ts dev",
    "dev:server": "bun scripts/dev-runner.ts dev:server",
    "dev:web": "bun scripts/dev-runner.ts dev:web",
    "dev:marketing": "turbo run dev --filter=@t3tools/marketing",
    "dev:desktop": "bun scripts/dev-runner.ts dev:desktop",
    "dev:desktop:bench": "bun scripts/desktop-benchmark-mvp.ts",
    "dev:desktop:sync-history": "bun scripts/sync-desktop-history.ts && bun scripts/dev-runner.ts dev:desktop",
    "start": "turbo run start --filter=t3",
    "start:desktop": "turbo run start --filter=@t3tools/desktop",
    "start:marketing": "turbo run preview --filter=@t3tools/marketing",
    "start:mock-update-server": "bun scripts/mock-update-server.ts",
    "build": "turbo run build",
    "build:marketing": "turbo run build --filter=@t3tools/marketing",
    "build:desktop": "turbo run build --filter=@t3tools/desktop --filter=t3",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "test:desktop-smoke": "turbo run smoke-test --filter=@t3tools/desktop",
    "perf:load": "bun scripts/performance-load-scenarios.ts",
    "preflight:release": "bun run fmt:check && bun run lint && bun run typecheck && bun run test && bun run --cwd apps/web test:browser && bun run perf:load -- --enforce && bun run --cwd apps/web check:bundle && bun run test:desktop-smoke",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build:contracts": "turbo run build --filter=@t3tools/contracts",
    "dist:desktop:artifact": "bun scripts/build-desktop-artifact.ts",
    "dist:desktop:dmg": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg",
    "dist:desktop:dmg:arm64": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg --arch arm64",
    "dist:desktop:dmg:x64": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg --arch x64",
    "dist:desktop:linux": "bun scripts/build-desktop-artifact.ts --platform linux --target AppImage --arch x64",
    "dist:desktop:win": "bun scripts/build-desktop-artifact.ts --platform win --target nsis",
    "dist:desktop:win:arm64": "bun scripts/build-desktop-artifact.ts --platform win --target nsis --arch arm64",
    "dist:desktop:win:x64": "bun scripts/build-desktop-artifact.ts --platform win --target nsis --arch x64",
    "deploy:desktop:local": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg --arch arm64 --local --output-dir release-local && MOUNT_DIR=\"$(mktemp -d)\" && hdiutil attach \"release-local/T3-Code-Local-0.0.21-arm64.dmg\" -mountpoint \"$MOUNT_DIR\" -nobrowse -quiet && rm -rf \"/Applications/T3 Code (Local).app\" && ditto \"$MOUNT_DIR/T3 Code (Local).app\" \"/Applications/T3 Code (Local).app\" && hdiutil detach \"$MOUNT_DIR\" -quiet && rmdir \"$MOUNT_DIR\"",
    "release:smoke": "bun scripts/release-smoke.ts",
    "logs:thread": "bun scripts/inspect-thread-logs.ts",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist .turbo apps/*/.turbo packages/*/.turbo",
    "sync:desktop-history": "bun scripts/sync-desktop-history.ts",
    "sync:vscode-icons": "node scripts/sync-vscode-icons.mjs"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.62.0",
    "turbo": "^2.9.7",
    "vitest": "catalog:"
  },
  "overrides": {
    "@effect/atom-react": "catalog:",
    "@effect/platform-bun": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/platform-node-shared": "catalog:",
    "@effect/sql-sqlite-bun": "catalog:",
    "@effect/vitest": "catalog:",
    "defu": "^6.1.7",
    "effect": "catalog:",
    "smol-toml": "^1.6.1",
    "yaml": "^2.8.4"
  },
  "engines": {
    "bun": "^1.3.11",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.11",
  "msw": {
    "workerDirectory": [
      "apps/web/public"
    ]
  },
  "trustedDependencies": [
    "node-pty",
    "electron"
  ]
}
